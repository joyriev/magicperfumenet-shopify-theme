  max-height: 85vh;
  background: #FFFFFF;
  border-radius: 24px;
  box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.25);
  padding: 0;
  overflow-y: auto;
  transform: translateY(30px);
  opacity: 0;
  visibility: hidden;
  transition: 0.4s cubic-bezier(0.16, 1, 0.3, 1);
  z-index: 10000;
  border: 1px solid rgba(0, 0, 0, 0.05);
}

.fc-search-popup.active {
  transform: translateY(0);
  opacity: 1;
