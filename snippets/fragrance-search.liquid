  line-height: 28px;
  font-size: 15px;
  font-weight: 700;
  flex-shrink: 0;
  box-shadow: 0 4px 8px rgba(196, 30, 58, 0.2);
}

/* ===== SECTION TITLES ===== */
.fc-section-title {
  font-size: 14px;
  font-weight: 800;
  color: #C41E3A;
  margin: 20px 20px 15px 20px;
  padding-bottom: 8px;
  border-bottom: 2px solid #EDE5DC;
  text-transform: uppercase;
  letter-spacing: 0.8px;
}

.fc-subsection-title {
  font-size: 14px;
  font-weight: 700;
  color: #2C2420;
  margin: 15px 20px 10px 20px;
}

/* ===== CATALOG RESULT ITEM ===== */
.fc-catalog-item {
  background: #FFFFFF;
  padding: 15px 20px;
  margin: 0;
  border-bottom: 1px solid #F0E8E0;
