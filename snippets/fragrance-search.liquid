<script>
(function() {
  // ===== WAIT FOR CATALOG TO LOAD =====
  let allPerfumes = [];
  let inspiredProducts = [];
  let catalogReady = false;
  let initAttempts = 0;
  const maxAttempts = 100; // 10 seconds (100 * 100ms)
  
  function initializeCatalog() {
    initAttempts++;
    
    // Check if catalog loaded
    if (typeof window.PerfumeCatalog !== 'undefined' && Object.keys(window.PerfumeCatalog).length > 0) {
      console.log('✓ Catalogue détecté, initialisation en cours...');
      
      // Load all perfumes from catalog
      for (let brandKey in window.PerfumeCatalog) {
        if (brandKey.startsWith('_')) continue;
        const perfumes = window.PerfumeCatalog[brandKey];
        if (Array.isArray(perfumes)) {
          allPerfumes.push(...perfumes);
        }
      }
      console.log('✓ Catalogue chargé:', allPerfumes.length, 'parfums');
      
      // Generate inspired products from the catalog's shopifyProduct data
      if (allPerfumes.length > 0) {
        inspiredProducts = allPerfumes.map(perfume => {
          if (perfume.shopifyProduct) {
            return {
              id: perfume.id,
              title: perfume.shopifyProduct.title,
              image: perfume.shopifyProduct.image,
              url: perfume.shopifyProduct.url,
              price: 1199, // €11.99 in cents
              brand: perfume.brand,
              number: perfume.productNumbers ? perfume.productNumbers[0] : null,
              gender: perfume.gender,
              inspiredBy: perfume.name
            };
          }
        }).filter(p => p !== undefined);
        
        console.log('✓ Produits inspirés générés:', inspiredProducts.length);
        catalogReady = true;
        return true;
      } else {
        console.warn('⚠️ Aucun produit shopify trouvé dans le catalogue');
      }
    } else {
      // Retry
      if (initAttempts < maxAttempts) {
        console.log('⏳ Attente du catalogue... (' + initAttempts + '/' + maxAttempts + ')');
        setTimeout(initializeCatalog, 100);
      } else {
        console.error('❌ Le catalogue n\'a pas pu charger après 10 secondes');
      }
    }
    
    return false;
  }

  // ===== ADVANCED FUZZY SEARCH =====
  function normalizeText(text) {
    if (!text) return '';
    
    let normalized = text.toLowerCase().trim();
    
    // Remove accents
    const accents = {
      'à': 'a', 'â': 'a', 'ä': 'a', 'á': 'a', 'ã': 'a', 'å': 'a',
      'é': 'e', 'è': 'e', 'ê': 'e', 'ë': 'e',
      'î': 'i', 'ï': 'i', 'í': 'i', 'ì': 'i',
      'ô': 'o', 'ö': 'o', 'ó': 'o', 'ò': 'o', 'õ': 'o',
      'ù': 'u', 'û': 'u', 'ü': 'u', 'ú': 'u',
      'ç': 'c', 'ÿ': 'y', 'ñ': 'n'
    };
    
    for (const [accented, base] of Object.entries(accents)) {
      normalized = normalized.split(accented).join(base);
    }
    
    // Remove punctuation
    normalized = normalized.replace(/[^a-z0-9\s]/g, ' ');
    normalized = normalized.replace(/\s+/g, ' ').trim();
    
    return normalized;
  }
  
  function getLevenshteinDistance(a, b) {
    const aLen = a.length;
    const bLen = b.length;
    
    if (aLen === 0) return bLen;
    if (bLen === 0) return aLen;
    
    const matrix = Array(bLen + 1).fill(null).map(() => Array(aLen + 1).fill(0));
    
    for (let i = 0; i <= aLen; i++) matrix[0][i] = i;
    for (let j = 0; j <= bLen; j++) matrix[j][0] = j;
    
    for (let j = 1; j <= bLen; j++) {
      for (let i = 1; i <= aLen; i++) {
        const cost = a[i - 1] === b[j - 1] ? 0 : 1;
        matrix[j][i] = Math.min(
          matrix[j][i - 1] + 1,
          matrix[j - 1][i] + 1,
          matrix[j - 1][i - 1] + cost
        );
      }
    }
    
    return matrix[bLen][aLen];
  }
  
  function getFuzzyScore(query, text) {
    const queryNorm = normalizeText(query);
    const textNorm = normalizeText(text);
    
    if (!queryNorm || !textNorm) return 0;
    
    // Exact match
    if (textNorm === queryNorm) return 100;
    
    // Contains
    if (textNorm.includes(queryNorm)) return 95;
    
    // Levenshtein distance
    const distance = getLevenshteinDistance(queryNorm, textNorm);
    const maxLen = Math.max(queryNorm.length, textNorm.length);
    
    if (distance <= 2) {
      return Math.max(0, 90 - (distance * 10));
    }
    
    // Word-by-word matching
    const queryWords = queryNorm.split(' ');
    const textWords = textNorm.split(' ');
    
    let matchedCount = 0;
    for (const qWord of queryWords) {
      if (qWord.length < 2) continue;
      for (const tWord of textWords) {
        if (tWord.includes(qWord) || qWord.includes(tWord)) {
          matchedCount++;
          break;
        }
        const wordDistance = getLevenshteinDistance(qWord, tWord);
        if (wordDistance <= 2 && Math.max(qWord.length, tWord.length) >= 3) {
          matchedCount += 0.7;
          break;
        }
      }
    }
    
    if (matchedCount > 0) {
      return Math.min(85, (matchedCount / queryWords.length) * 85);
    }
    
    return 0;
  }
  
  // ===== SEARCH CATALOG WITH FUZZY MATCHING =====
  function searchCatalog(query) {
    if (!query || query.length < 1) return [];
    
    const results = [];
    const addedIds = new Set();
    
    allPerfumes.forEach(perfume => {
      let bestScore = 0;
      
      // Brand match
      const brandScore = getFuzzyScore(query, perfume.brand);
      bestScore = Math.max(bestScore, brandScore);
      
      // Name match
      const nameScore = getFuzzyScore(query, perfume.name);
      bestScore = Math.max(bestScore, nameScore);
      
      // Notes match
      if (bestScore < 70) {
        const allNotes = [
          ...(perfume.top_notes || []),
          ...(perfume.heart_notes || []),
          ...(perfume.base_notes || [])
        ];
        for (const note of allNotes) {
          const noteScore = getFuzzyScore(query, note);
          if (noteScore > bestScore) bestScore = noteScore;
        }
      }
      
      // Description match
      if (bestScore < 60 && perfume.description) {
        const descScore = getFuzzyScore(query, perfume.description);
        bestScore = Math.max(bestScore, descScore);
      }
      
      // Product number match
      if (perfume.productNumbers && perfume.productNumbers.length) {
        for (const num of perfume.productNumbers) {
          if (query.includes(num) || num.includes(query)) {
            bestScore = 100;
          }
        }
      }
      
      if (bestScore > 30 && !addedIds.has(perfume.id)) {
        results.push({ perfume, score: bestScore });
        addedIds.add(perfume.id);
      }
    });
    
    return results.sort((a, b) => b.score - a.score);
  }
  
  // ===== FIND INSPIRED PRODUCT - IMPROVED =====
  function findInspiredProduct(perfume) {
    if (!perfume) return null;
    
    const perfumeNameNorm = normalizeText(perfume.name);
    const perfumeBrandNorm = normalizeText(perfume.brand);
    
    console.log('🔍 Recherche produit inspiré pour:', perfume.name, 'de', perfume.brand);
    
    let bestMatch = null;
    let bestScore = 0;
    
    inspiredProducts.forEach(product => {
      let score = 0;
      
      // Brand match (exact or contains)
      const productBrandNorm = normalizeText(product.brand);
      const productInspiredByNorm = normalizeText(product.inspiredBy);
      
      if (productBrandNorm === perfumeBrandNorm || perfumeBrandNorm.includes(productBrandNorm) || productBrandNorm.includes(perfumeBrandNorm)) {
        score += 60;
        console.log('✓ Match marque:', product.brand, 'score:', score);
      }
      
      // Name match
      if (productInspiredByNorm === perfumeNameNorm || 
          perfumeNameNorm.includes(productInspiredByNorm) || 
          productInspiredByNorm.includes(perfumeNameNorm)) {
        score += 40;
        console.log('✓ Match nom:', product.inspiredBy, 'score:', score);
      }
      
      // Number match
      if (product.number && perfume.productNumbers && 
          perfume.productNumbers.some(num => num === product.number || num === product.number.padStart(3, '0'))) {
        score = 100;
        console.log('✓ Match numéro:', product.number);
      }
      
      if (score > bestScore) {
        bestScore = score;
        bestMatch = product;
      }
    });
    
    if (bestMatch) {
      console.log('✅ Produit inspiré trouvé:', bestMatch.title);
    } else {
      console.log('❌ Aucun produit inspiré trouvé pour:', perfume.name);
    }
    
    return bestMatch;
  }
  
  // ===== SMART RECOMMENDATIONS - IMPROVED =====
  function getRecommendations(perfume, currentProduct) {
    if (!perfume) return [];
    
    const recommendations = [];
    const addedIds = new Set();
    const perfumeGender = perfume.gender?.toLowerCase() || '';
    const perfumeBrandNorm = normalizeText(perfume.brand);
    
    console.log('🎯 Recherche recommandations pour:', perfume.name, 'Genre:', perfumeGender);
    
    // STEP 1: Try same brand products
    const sameBrandProducts = inspiredProducts.filter(p => {
      const pBrandNorm = normalizeText(p.brand);
      const isSameBrand = pBrandNorm === perfumeBrandNorm || 
                          pBrandNorm.includes(perfumeBrandNorm) || 
                          perfumeBrandNorm.includes(pBrandNorm);
      const isNotCurrent = p.id !== currentProduct?.id;
      const genderMatch = perfumeGender === '' || p.gender?.toLowerCase() === perfumeGender;
      
      return isSameBrand && isNotCurrent && genderMatch;
    });
    
    if (sameBrandProducts.length > 0) {
      console.log('✓ Trouvé', sameBrandProducts.length, 'produits de la même marque');
      return sameBrandProducts.slice(0, 1);
    }
    
    // STEP 2: For single-product brands, recommend popular products in same category
    const fragranceCategories = {
      'Homme': {
        woody: ['Dior', 'Tom Ford', 'Chanel', 'Hermès', 'Giorgio Armani'],
        fresh: ['Dior', 'Chanel', 'Hugo Boss', 'Paco Rabanne', 'Davidoff'],
        oriental: ['Tom Ford', 'Jean Paul Gaultier', 'Joop!', 'Paco Rabanne', 'Yves Saint Laurent'],
        aromatic: ['Hugo Boss', 'Dior', 'Chanel', 'Paco Rabanne', 'Jean Paul Gaultier']
      },
      'Femme': {
        floral: ['Chanel', 'Dior', 'Lancôme', 'Gucci', 'Yves Saint Laurent', 'Givenchy'],
        gourmand: ['Mugler', 'Prada', 'Tom Ford', 'Yves Saint Laurent', 'Carolina Herrera'],
        oriental: ['Yves Saint Laurent', 'Tom Ford', 'Givenchy', 'Prada', 'Giorgio Armani'],
        fresh: ['Dolce & Gabbana', 'Giorgio Armani', 'Hugo Boss', 'Kenzo', 'Chanel']
      }
    };
    
    // Determine category based on perfume name and brand
    let category = '';
    const nameLower = perfume.name.toLowerCase();
    const brandLower = perfume.brand.toLowerCase();
    
    if (perfumeGender === 'homme') {
      if (nameLower.includes('wood') || nameLower.includes('oud') || nameLower.includes('terre')) category = 'woody';
      else if (nameLower.includes('acqua') || nameLower.includes('water') || nameLower.includes('sport') || nameLower.includes('cool')) category = 'fresh';
      else if (nameLower.includes('opium') || nameLower.includes('million') || nameLower.includes('male') || nameLower.includes('scandal')) category = 'oriental';
      else category = 'aromatic';
      
      const recommendedBrands = fragranceCategories.Homme[category] || fragranceCategories.Homme.aromatic;
      console.log('📋 Catégorie homme:', category, 'Marques recommandées:', recommendedBrands);
      
      for (const brand of recommendedBrands) {
        if (recommendations.length >= 1) break;
        const product = inspiredProducts.find(p => {
          const pBrand = p.brand.toLowerCase();
          const isBrandMatch = pBrand === brand.toLowerCase() || pBrand.includes(brand.toLowerCase());
          const genderMatch = p.gender?.toLowerCase() === 'homme';
          const isNotCurrent = p.id !== currentProduct?.id;
          return isBrandMatch && genderMatch && isNotCurrent;
        });
        if (product && !addedIds.has(product.id)) {
          console.log('✅ Recommandation trouvée:', product.title);
          recommendations.push(product);
          addedIds.add(product.id);
        }
      }
    } 
    else if (perfumeGender === 'femme') {
      if (nameLower.includes('rose') || nameLower.includes('flower') || nameLower.includes('jasmine') || nameLower.includes('coco')) category = 'floral';
      else if (nameLower.includes('vanille') || nameLower.includes('candy') || nameLower.includes('cherry') || nameLower.includes('angel')) category = 'gourmand';
      else if (nameLower.includes('opium') || nameLower.includes('paradoxe') || nameLower.includes('good girl')) category = 'oriental';
      else category = 'floral';
      
      const recommendedBrands = fragranceCategories.Femme[category] || fragranceCategories.Femme.floral;
      console.log('📋 Catégorie femme:', category, 'Marques recommandées:', recommendedBrands);
      
      for (const brand of recommendedBrands) {
        if (recommendations.length >= 1) break;
        const product = inspiredProducts.find(p => {
          const pBrand = p.brand.toLowerCase();
          const isBrandMatch = pBrand === brand.toLowerCase() || pBrand.includes(brand.toLowerCase());
          const genderMatch = p.gender?.toLowerCase() === 'femme';
          const isNotCurrent = p.id !== currentProduct?.id;
          return isBrandMatch && genderMatch && isNotCurrent;
        });
        if (product && !addedIds.has(product.id)) {
          console.log('✅ Recommandation trouvée:', product.title);
          recommendations.push(product);
          addedIds.add(product.id);
        }
      }
    }
    
    // STEP 3: Fallback to popular products of same gender
    if (recommendations.length === 0) {
      console.log('⚠️ Aucune recommandation spécifique, fallback aux produits populaires');
      const popularProducts = inspiredProducts.filter(p => {
        const genderMatch = perfumeGender === '' || p.gender?.toLowerCase() === perfumeGender;
        const isNotCurrent = p.id !== currentProduct?.id;
        return genderMatch && isNotCurrent;
      }).slice(0, 1);
      
      if (popularProducts.length > 0) {
        console.log('✅ Recommandation fallback:', popularProducts[0].title);
        return popularProducts;
      }
    }
    
    return recommendations.slice(0, 1);
  }
  
  // ===== RENDER FUNCTIONS =====
  function formatPrice(priceInCents) {
    return '€' + (priceInCents / 100).toFixed(2);
  }
  
  function renderCatalogItem(perfume) {
    const imageUrl = perfume.image || 'https://via.placeholder.com/60x60?text=Parfum';
    
    return `
      <div class="fc-catalog-item" onclick="window.fcShowPerfumeDetail('${perfume.id}')">
        <img class="fc-catalog-image" src="${imageUrl}" alt="${perfume.name}" loading="lazy" onerror="this.src='https://via.placeholder.com/60x60?text=Parfum'">
        <div class="fc-catalog-info">
          <div class="fc-catalog-name">${perfume.name}</div>
          <div class="fc-catalog-brand">${perfume.brand}</div>
          ${perfume.year ? `<div class="fc-catalog-year">${perfume.year}</div>` : ''}
        </div>
      </div>
    `;
  }
  
  function renderInspiredCard(product, badge) {
    const priceFormatted = formatPrice(product.price);
    
    return `
      <div class="fc-product-card">
        <div class="fc-badge">${badge}</div>
        <div class="fc-product-inner">
          <img class="fc-product-image" src="${product.image}" alt="${product.title}" loading="lazy" onerror="this.src='https://via.placeholder.com/150x150?text=Parfum'">
          <div class="fc-product-title">${product.title}</div>
          <div class="fc-product-price">${priceFormatted}</div>
          <button class="fc-add-to-cart" onclick="event.stopPropagation(); window.fcAddToCart('${product.url}', event)">Ajouter au panier</button>
          <div>
            <span class="fc-view-link" onclick="event.stopPropagation(); window.fcViewDetails('${product.url}')">Voir les détails</span>
          </div>
        </div>
      </div>
    `;
  }
  
  // ===== DETAILED VIEW =====
  window.fcShowPerfumeDetail = function(perfumeId) {
    if (!catalogReady) {
      console.warn('Catalogue non prêt');
      return;
    }
    
    const perfume = allPerfumes.find(p => p.id === perfumeId);
    if (!perfume) return;
    
    const stepsEl = document.getElementById('fcSteps');
    const contentEl = document.getElementById('fcContent');
    stepsEl.style.display = 'none';
    
    const inspiredProduct = findInspiredProduct(perfume);
    const recommendation = getRecommendations(perfume, inspiredProduct);
    
    let html = `
      <button class="fc-back-btn" onclick="window.fcGoBack()">Retour</button>
    `;
    
    // Detailed catalog information
    html += `
      <div class="fc-detailed-view">
        <div class="fc-detailed-header">
          <img class="fc-detailed-image" src="${perfume.image}" alt="${perfume.name}" loading="lazy" onerror="this.src='https://via.placeholder.com/100x100?text=Parfum'">
          <div class="fc-detailed-info">
            <div class="fc-detailed-name">${perfume.name}</div>
            <div class="fc-detailed-brand">${perfume.brand}</div>
            ${perfume.year ? `<div class="fc-detailed-year">Année: ${perfume.year}</div>` : ''}
            ${perfume.gender ? `<div class="fc-detailed-gender">Pour: ${perfume.gender}</div>` : ''}
          </div>
        </div>
    `;
    
    // Notes section
    if (perfume.top_notes || perfume.heart_notes || perfume.base_notes) {
      html += `<div class="fc-notes-section">`;
      
      if (perfume.top_notes && perfume.top_notes.length) {
        html += `
          <div class="fc-note-category">
            <h4>NOTES DE TÊTE</h4>
            <div class="fc-note-tags">
              ${perfume.top_notes.map(note => `<span class="fc-note-tag">${note}</span>`).join('')}
            </div>
          </div>
        `;
      }
      
      if (perfume.heart_notes && perfume.heart_notes.length) {
        html += `
          <div class="fc-note-category">
            <h4>NOTES DE CŒUR</h4>
            <div class="fc-note-tags">
              ${perfume.heart_notes.map(note => `<span class="fc-note-tag">${note}</span>`).join('')}
            </div>
          </div>
        `;
      }
      
      if (perfume.base_notes && perfume.base_notes.length) {
        html += `
          <div class="fc-note-category">
            <h4>NOTES DE FOND</h4>
            <div class="fc-note-tags">
              ${perfume.base_notes.map(note => `<span class="fc-note-tag">${note}</span>`).join('')}
            </div>
          </div>
        `;
      }
      
      html += `</div>`;
    }
    
    // Description
    if (perfume.description) {
      html += `<div class="fc-description">${perfume.description}</div>`;
    }
    
    html += `</div>`;
    
    // Inspired version section
    if (inspiredProduct) {
      html += `<div class="fc-section-title">NOTRE VERSION INSPIRÉE</div>`;
      html += `<div class="fc-grid-2col">`;
      html += renderInspiredCard(inspiredProduct, `Inspiré de ${perfume.name}`);
      
      // Recommendation
      if (recommendation && recommendation.length > 0) {
        html += renderInspiredCard(recommendation[0], 'Vous pourriez aimer');
      } else {
        html += `<div class="fc-product-card" style="visibility: hidden;"></div>`;
      }
      
      html += `</div>`;
    }
    
    contentEl.innerHTML = html;
  };
  
  // ===== SEARCH FUNCTION =====
  let searchTimer = null;
  
  function performSearch(query) {
    const contentEl = document.getElementById('fcContent');
    
    if (!catalogReady) {
      contentEl.innerHTML = '<div class="fc-loading">Chargement du catalogue...</div>';
      return;
    }
    
    contentEl.innerHTML = '<div class="fc-loading">Recherche en cours...</div>';
    
    setTimeout(() => {
      const catalogResults = searchCatalog(query);
      
      let html = '';
      
      if (catalogResults.length > 0) {
        html += `<div class="fc-section-title">PARFUMS (${catalogResults.length})</div>`;
        catalogResults.slice(0, 10).forEach(result => {
          html += renderCatalogItem(result.perfume);
        });
      } else {
        html = '<div class="fc-no-results">Aucun parfum trouvé pour "' + query + '"</div>';
      }
      
      contentEl.innerHTML = html;
    }, 300);
  }
  
  function handleSearch() {
    const query = document.getElementById('fcSearchInput').value.trim();
    const stepsEl = document.getElementById('fcSteps');
    
    if (!catalogReady) {
      document.getElementById('fcContent').innerHTML = '<div class="fc-loading">Chargement du catalogue...</div>';
      return;
    }
    
    if (query.length < 1) {
      stepsEl.style.display = 'block';
      document.getElementById('fcContent').innerHTML = '';
      return;
    }
    
    stepsEl.style.display = 'none';
    clearTimeout(searchTimer);
    searchTimer = setTimeout(() => performSearch(query), 300);
  }
  
  // ===== BACK FUNCTION =====
  window.fcGoBack = function() {
    const stepsEl = document.getElementById('fcSteps');
    const contentEl = document.getElementById('fcContent');
    const searchInput = document.getElementById('fcSearchInput');
    
    stepsEl.style.display = 'block';
    if (searchInput.value.trim()) {
      performSearch(searchInput.value.trim());
    } else {
      contentEl.innerHTML = '';
    }
  };
  
  // ===== ADD TO CART =====
  window.fcAddToCart = function(productUrl, event) {
    if (event) event.stopPropagation();
    
    const btn = event?.target || document.activeElement;
    const originalText = btn.innerText;
    const originalBackground = btn.style.background;
    
    btn.innerText = 'Ajout...';
    btn.disabled = true;
    
    let handle = '';
    if (productUrl.includes('/products/')) {
      handle = productUrl.split('/products/')[1].split('?')[0].split('#')[0];
    }
    
    if (!handle) {
      btn.innerText = 'Erreur';
      setTimeout(() => {
        btn.innerText = originalText;
        btn.disabled = false;
      }, 2000);
      return;
    }
    
    fetch(`/products/${handle}.js`)
      .then(res => res.json())
      .then(product => {
        const variantId = product.variants?.[0]?.id;
        if (!variantId) throw new Error('No variant');
        
        return fetch('/cart/add.js', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ id: variantId, quantity: 1 })
        });
      })
      .then(res => res.json())
      .then(() => {
        btn.innerText = '✓ Ajouté!';
        btn.style.background = '#2E7D32';
        fetchCartAndUpdate();
        setTimeout(() => {
          btn.innerText = originalText;
          btn.style.background = originalBackground || '#C41E3A';
          btn.disabled = false;
        }, 2000);
      })
      .catch(() => {
        btn.innerText = 'Erreur';
        btn.style.background = '#c62828';
        setTimeout(() => {
          btn.innerText = originalText;
          btn.style.background = originalBackground || '#C41E3A';
          btn.disabled = false;
        }, 2000);
      });
  };
  
  window.fcViewDetails = function(url) {
    window.location.href = url;
  };
  
  // ===== TOGGLE SEARCH =====
  window.fcToggleSearch = function() {
    const popup = document.getElementById('fcSearchPopup');
    if (popup.classList.contains('active')) {
      popup.classList.remove('active');
    } else {
      popup.classList.add('active');
      document.getElementById('fcSearchInput')?.focus();
      fetchCartAndUpdate();
    }
  };
  
  // ===== CART FUNCTIONS =====
  function updateOfferDisplay(itemCount) {
    const offerBanner = document.getElementById('fcOfferBanner');
    const offerStatus = document.getElementById('fcOfferStatus');
    const offerProgress = document.getElementById('fcOfferProgress');
    const offerMessage = document.getElementById('fcOfferMessage');
    const offerSubtext = document.getElementById('fcOfferSubtext');
    
    if (!offerStatus) return;
    
    const percentage = Math.min((itemCount / 3) * 100, 100);
    if (offerProgress) offerProgress.style.width = percentage + '%';
    
    if (itemCount >= 3) {
      offerStatus.textContent = '🎉 GRATUIT!';
      if (offerSubtext) offerSubtext.textContent = 'Vous obtenez un cadeau gratuit!';
      if (offerMessage) offerMessage.textContent = '🎉 Vous obtenez un CADEAU GRATUIT!';
      if (offerBanner) offerBanner.classList.add('qualified');
    } else {
      const needed = 3 - itemCount;
      offerStatus.textContent = `${itemCount}/3`;
      if (offerSubtext) offerSubtext.textContent = `Ajoutez ${needed} de plus pour un cadeau gratuit`;
      if (offerMessage) offerMessage.textContent = `Ajoutez ${needed} article${needed > 1 ? 's' : ''} de plus pour un cadeau gratuit`;
      if (offerBanner) offerBanner.classList.remove('qualified');
    }
  }
  
  function fetchCartAndUpdate() {
    return fetch('/cart.js')
      .then(res => res.json())
      .then(cart => {
        updateOfferDisplay(cart.item_count);
        return cart;
      })
      .catch(() => ({ item_count: 0 }));
  }
  
  // ===== INITIALIZATION =====
  // Start checking for catalog immediately (don't wait for DOMContentLoaded)
  initializeCatalog();
  
  document.addEventListener('DOMContentLoaded', function() {
    const searchInput = document.getElementById('fcSearchInput');
    const clearSearch = document.getElementById('fcClearSearch');
    const searchPopup = document.getElementById('fcSearchPopup');
    const stickyButton = document.getElementById('fcStickyButton');
    
    if (searchInput) searchInput.addEventListener('keyup', handleSearch);
    
    if (clearSearch) {
      clearSearch.addEventListener('click', function() {
        searchInput.value = '';
        searchInput.focus();
        document.getElementById('fcSteps').style.display = 'block';
        document.getElementById('fcContent').innerHTML = '';
      });
    }
    
    setTimeout(fetchCartAndUpdate, 500);
    
    // Close on outside click
    document.addEventListener('click', function(event) {
      if (searchPopup && stickyButton && !searchPopup.contains(event.target) && !stickyButton.contains(event.target) && searchPopup.classList.contains('active')) {
        searchPopup.classList.remove('active');
      }
    });
    
    // Close on ESC
    document.addEventListener('keydown', function(e) {
      if (e.key === 'Escape' && searchPopup && searchPopup.classList.contains('active')) {
        searchPopup.classList.remove('active');
      }
    });
    
    if (searchPopup) searchPopup.addEventListener('click', function(e) { e.stopPropagation(); });
    
    console.log('✓ Recherche initialisée');
  });
})();
</script>