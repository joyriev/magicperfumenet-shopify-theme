// Helper functions
function getAllPerfumes() {
  const all = [];
  for (const brand in PerfumeCatalog) {
    if (Array.isArray(PerfumeCatalog[brand])) {
      all.push(...PerfumeCatalog[brand]);
    }
  }
  return all;
}

window.PerfumeCatalog = PerfumeCatalog;
window.getAllPerfumes = getAllPerfumes;

// ===== SEARCH POPUP FUNCTIONALITY =====
(function() {
  let allPerfumes = [];
  let catalogReady = false;
  
  function normalizeText(text) {
    if (!text) return '';
    let normalized = text.toLowerCase().trim();
    const accents = {
      'à': 'a', 'â': 'a', 'ä': 'a', 'á': 'a', 'ã': 'a', 'å': 'a',
      'é': 'e', 'è': 'e', 'ê': 'e', 'ë': 'e',
      'î': 'i', 'ï': 'i', 'í': 'i', 'ì': 'i',
      'ô': 'o', 'ö': 'o', 'ó': 'o', 'ò': 'o', 'õ': 'o',
      'ù': 'u', 'û': 'u', 'ü': 'u', 'ú': 'u',
      'ç': 'c', 'ÿ': 'y', 'ñ': 'n'
    };
    for (const [accented, base] of Object.entries(accents)) {
      normalized = normalized.split(accented).join(base);
    }
    normalized = normalized.replace(/[^a-z0-9\s]/g, ' ');
    normalized = normalized.replace(/\s+/g, ' ').trim();
    return normalized;
  }
  
  function getFuzzyScore(query, text) {
    const queryNorm = normalizeText(query);
    const textNorm = normalizeText(text);
    if (!queryNorm || !textNorm) return 0;
    if (textNorm === queryNorm) return 100;
    if (textNorm.includes(queryNorm)) return 95;
    const queryWords = queryNorm.split(' ');
    let matchedCount = 0;
    for (const qWord of queryWords) {
      if (qWord.length < 2) continue;
      if (textNorm.includes(qWord)) {
        matchedCount += 1;
      } else if (textNorm.replace(/\s/g, '').includes(qWord.replace(/\s/g, ''))) {
        matchedCount += 0.7;
      }
    }
    if (matchedCount > 0) {
      return Math.min(80, (matchedCount / queryWords.length) * 80);
    }
    return 0;
  }
  
  function searchCatalog(query) {
    if (!query || query.length < 1) return [];
    const results = [];
    const addedIds = new Set();
    allPerfumes.forEach(perfume => {
      let bestScore = 0;
      bestScore = Math.max(bestScore, getFuzzyScore(query, perfume.brand));
      bestScore = Math.max(bestScore, getFuzzyScore(query, perfume.name));
      if (perfume.productNumbers && perfume.productNumbers.length) {
        for (const num of perfume.productNumbers) {
          bestScore = Math.max(bestScore, getFuzzyScore(query, num));
        }
      }
      if (bestScore > 30 && !addedIds.has(perfume.id)) {
        results.push({ perfume, score: bestScore });
        addedIds.add(perfume.id);
      }
    });
    return results.sort((a, b) => b.score - a.score);
  }
  
  function renderCatalogItem(perfume) {
    const imageUrl = perfume.image || perfume.shopifyProduct?.image || 'https://via.placeholder.com/60x60?text=Parfum';
    const genderIcon = perfume.gender === 'Homme' ? '👨' : (perfume.gender === 'Femme' ? '👩' : '👥');
    return `
      <div class="fc-catalog-item" onclick="window.fcShowPerfumeDetail('${perfume.id}')">
        <img class="fc-catalog-image" src="${imageUrl}" alt="${perfume.name}" loading="lazy" onerror="this.src='https://via.placeholder.com/60x60?text=Parfum'">
        <div class="fc-catalog-info">
          <div class="fc-catalog-name">${perfume.name}</div>
          <div class="fc-catalog-brand">${genderIcon} ${perfume.brand}</div>
          ${perfume.productNumbers ? `<div class="fc-catalog-year">N° ${perfume.productNumbers.join(', ')}</div>` : ''}
        </div>
      </div>
    `;
  }
  
  function renderInspiredCard(product, badge) {
    const priceFormatted = product.shopifyProduct?.price || '€11.99';
    const imageUrl = product.image || product.shopifyProduct?.image;
    const variantId = product.shopifyProduct?.variantId;
    const productUrl = product.shopifyProduct?.url || product.url;
    return `
      <div class="fc-product-card">
        <div class="fc-badge">${badge}</div>
        <div class="fc-product-inner">
          <img class="fc-product-image" src="${imageUrl}" alt="${product.name}" loading="lazy" onerror="this.src='https://via.placeholder.com/150x150?text=Parfum'">
          <div class="fc-product-title">${product.name}</div>
          <div class="fc-product-brand">${product.brand}</div>
          <div class="fc-product-price">${priceFormatted}</div>
          <button class="fc-add-to-cart" onclick="event.stopPropagation(); window.fcAddToCart('${productUrl}', '${variantId}', event)">Ajouter au panier</button>
          <div><span class="fc-view-link" onclick="event.stopPropagation(); window.fcViewDetails('${productUrl}')">Voir les détails</span></div>
        </div>
      </div>
    `;
  }
  
  function performSearch(query) {
    const contentEl = document.getElementById('fcContent');
    if (!catalogReady) {
      contentEl.innerHTML = '<div class="fc-loading">Chargement du catalogue...</div>';
      return;
    }
    if (!query || query.trim().length < 1) {
      contentEl.innerHTML = '';
      return;
    }
    contentEl.innerHTML = '<div class="fc-loading">Recherche en cours...</div>';
    setTimeout(() => {
      const catalogResults = searchCatalog(query);
      let html = '';
      if (catalogResults.length > 0) {
        html += `<div class="fc-section-title">🔍 RÉSULTATS (${catalogResults.length})</div>`;
        catalogResults.slice(0, 12).forEach(result => {
          html += renderCatalogItem(result.perfume);
        });
      } else {
        html = '<div class="fc-no-results">Aucun parfum trouvé pour "' + query + '"</div>';
        const popularPerfumes = allPerfumes.slice(0, 6);
        if (popularPerfumes.length > 0) {
          html += `<div class="fc-section-title">✨ PARFUMS POPULAIRES</div>`;
          html += `<div class="fc-grid-2col" style="padding: 0 20px 20px 20px;">`;
          popularPerfumes.forEach(perfume => {
            html += renderInspiredCard(perfume, perfume.brand);
          });
          html += `</div>`;
        }
      }
      contentEl.innerHTML = html;
    }, 300);
  }
  
  function handleSearch() {
    const query = document.getElementById('fcSearchInput')?.value.trim() || '';
    const stepsEl = document.getElementById('fcSteps');
    const contentEl = document.getElementById('fcContent');
    if (!catalogReady) {
      contentEl.innerHTML = '<div class="fc-loading">Chargement du catalogue...</div>';
      return;
    }
    if (query.length < 1) {
      if (stepsEl) stepsEl.style.display = 'block';
      if (contentEl) contentEl.innerHTML = '';
      return;
    }
    if (stepsEl) stepsEl.style.display = 'none';
    performSearch(query);
  }
  
  window.fcShowPerfumeDetail = function(perfumeId) {
    const perfume = allPerfumes.find(p => p.id === perfumeId);
    if (!perfume) return;
    const stepsEl = document.getElementById('fcSteps');
    const contentEl = document.getElementById('fcContent');
    if (stepsEl) stepsEl.style.display = 'none';
    const genderIcon = perfume.gender === 'Homme' ? '👨' : (perfume.gender === 'Femme' ? '👩' : '👥');
    const imageUrl = perfume.image || perfume.shopifyProduct?.image;
    let html = `<button class="fc-back-btn" onclick="window.fcGoBack()">← Retour</button>
      <div class="fc-detailed-view">
        <div class="fc-detailed-header">
          <img class="fc-detailed-image" src="${imageUrl}" alt="${perfume.name}" loading="lazy">
          <div class="fc-detailed-info">
            <div class="fc-detailed-name">${perfume.name}</div>
            <div class="fc-detailed-brand">${genderIcon} ${perfume.brand}</div>
            ${perfume.year ? `<div class="fc-detailed-year">Année: ${perfume.year}</div>` : ''}
            ${perfume.gender ? `<div class="fc-detailed-gender">Pour: ${perfume.gender}</div>` : ''}
          </div>
        </div>`;
    if ((perfume.top_notes && perfume.top_notes.length) || (perfume.heart_notes && perfume.heart_notes.length) || (perfume.base_notes && perfume.base_notes.length)) {
      html += `<div class="fc-notes-section">`;
      if (perfume.top_notes && perfume.top_notes.length) {
        html += `<div class="fc-note-category"><h4>NOTES DE TÊTE</h4><div class="fc-note-tags">${perfume.top_notes.map(n => `<span class="fc-note-tag">${n}</span>`).join('')}</div></div>`;
      }
      if (perfume.heart_notes && perfume.heart_notes.length) {
        html += `<div class="fc-note-category"><h4>NOTES DE CŒUR</h4><div class="fc-note-tags">${perfume.heart_notes.map(n => `<span class="fc-note-tag">${n}</span>`).join('')}</div></div>`;
      }
      if (perfume.base_notes && perfume.base_notes.length) {
        html += `<div class="fc-note-category"><h4>NOTES DE FOND</h4><div class="fc-note-tags">${perfume.base_notes.map(n => `<span class="fc-note-tag">${n}</span>`).join('')}</div></div>`;
      }
      html += `</div>`;
    }
    if (perfume.description) {
      html += `<div class="fc-description">${perfume.description}</div>`;
    }
    html += `</div>`;
    contentEl.innerHTML = html;
  };
  
  window.fcGoBack = function() {
    const stepsEl = document.getElementById('fcSteps');
    const contentEl = document.getElementById('fcContent');
    const searchInput = document.getElementById('fcSearchInput');
    if (stepsEl) stepsEl.style.display = 'block';
    if (searchInput && searchInput.value.trim()) {
      performSearch(searchInput.value.trim());
    } else {
      contentEl.innerHTML = '';
    }
  };
  
  window.fcAddToCart = function(productUrl, variantId, event) {
    if (event) event.stopPropagation();
    const btn = event?.target || document.activeElement;
    const originalText = btn.innerText;
    btn.innerText = 'Ajout...';
    btn.disabled = true;
    if (!variantId) {
      let handle = productUrl.split('/products/')[1]?.split('?')[0];
      if (handle) {
        fetch(`/products/${handle}.js`).then(res => res.json()).then(product => {
          const vid = product.variants?.[0]?.id;
          if (vid) addToCartWithVariant(vid, btn, originalText);
          else throw new Error('No variant');
        }).catch(() => resetButton(btn, originalText));
      } else { resetButton(btn, originalText); }
    } else {
      addToCartWithVariant(variantId, btn, originalText);
    }
  };
  
  function addToCartWithVariant(variantId, btn, originalText) {
    fetch('/cart/add.js', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ id: parseInt(variantId), quantity: 1 })
    }).then(() => {
      btn.innerText = '✓ Ajouté!';
      btn.style.background = '#2E7D32';
      fetchCartAndUpdate();
      setTimeout(() => resetButton(btn, originalText), 2000);
    }).catch(() => resetButton(btn, originalText));
  }
  
  function resetButton(btn, originalText) {
    btn.innerText = originalText;
    btn.style.background = '#C41E3A';
    btn.disabled = false;
  }
  
  window.fcViewDetails = function(url) { window.location.href = url; };
  window.fcToggleSearch = function() {
    const popup = document.getElementById('fcSearchPopup');
    if (popup) {
      if (popup.classList.contains('active')) popup.classList.remove('active');
      else { popup.classList.add('active'); document.getElementById('fcSearchInput')?.focus(); fetchCartAndUpdate(); }
    }
  };
  
  function updateOfferDisplay(itemCount) {
    const offerStatus = document.getElementById('fcOfferStatus');
    const offerProgress = document.getElementById('fcOfferProgress');
    const offerMessage = document.getElementById('fcOfferMessage');
    const offerSubtext = document.getElementById('fcOfferSubtext');
    if (!offerStatus) return;
    const percentage = Math.min((itemCount / 3) * 100, 100);
    if (offerProgress) offerProgress.style.width = percentage + '%';
    if (itemCount >= 3) {
      offerStatus.textContent = '🎉 GRATUIT!';
      if (offerSubtext) offerSubtext.textContent = 'Vous obtenez un cadeau gratuit!';
      if (offerMessage) offerMessage.textContent = '🎉 Vous obtenez un CADEAU GRATUIT!';
    } else {
      const needed = 3 - itemCount;
      offerStatus.textContent = `${itemCount}/3`;
      if (offerSubtext) offerSubtext.textContent = `Ajoutez ${needed} de plus pour un cadeau gratuit`;
      if (offerMessage) offerMessage.textContent = `Ajoutez ${needed} article${needed > 1 ? 's' : ''} de plus pour un cadeau gratuit`;
    }
  }
  
  function fetchCartAndUpdate() {
    fetch('/cart.js').then(res => res.json()).then(cart => updateOfferDisplay(cart.item_count)).catch(() => updateOfferDisplay(0));
  }
  
  function initializeCatalog() {
    allPerfumes = getAllPerfumes();
    catalogReady = true;
    console.log('✓ Catalogue chargé avec', allPerfumes.length, 'parfums');
  }
  
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', function() {
      initializeCatalog();
      const searchInput = document.getElementById('fcSearchInput');
      const clearSearch = document.getElementById('fcClearSearch');
      if (searchInput) searchInput.addEventListener('keyup', handleSearch);
      if (clearSearch) {
        clearSearch.addEventListener('click', function() {
          if (searchInput) searchInput.value = '';
          const stepsEl = document.getElementById('fcSteps');
          const contentEl = document.getElementById('fcContent');
          if (stepsEl) stepsEl.style.display = 'block';
          if (contentEl) contentEl.innerHTML = '';
        });
      }
      setTimeout(fetchCartAndUpdate, 500);
      const searchPopup = document.getElementById('fcSearchPopup');
      const stickyButton = document.getElementById('fcStickyButton');
      document.addEventListener('click', function(event) {
        if (searchPopup && stickyButton && !searchPopup.contains(event.target) && !stickyButton.contains(event.target) && searchPopup.classList.contains('active')) {
          searchPopup.classList.remove('active');
        }
      });
      document.addEventListener('keydown', function(e) {
        if (e.key === 'Escape' && searchPopup && searchPopup.classList.contains('active')) {
          searchPopup.classList.remove('active');
        }
      });
      if (searchPopup) searchPopup.addEventListener('click', function(e) { e.stopPropagation(); });
    });
  } else {
    initializeCatalog();
  }
})();
</script>