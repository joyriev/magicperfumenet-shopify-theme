  // ===== ADVANCED FUZZY SEARCH =====
  function normalizeText(text) {
    if (!text) return '';
    
    let normalized = text.toLowerCase().trim();
    
    // Remove accents
    const accents = {
      'à': 'a', 'â': 'a', 'ä': 'a', 'á': 'a', 'ã': 'a', 'å': 'a',
      'é': 'e', 'è': 'e', 'ê': 'e', 'ë': 'e',
      'î': 'i', 'ï': 'i', 'í': 'i', 'ì': 'i',
      'ô': 'o', 'ö': 'o', 'ó': 'o', 'ò': 'o', 'õ': 'o',
      'ù': 'u', 'û': 'u', 'ü': 'u', 'ú': 'u',
      'ç': 'c', 'ÿ': 'y', 'ñ': 'n'
    };
    
    for (const [accented, base] of Object.entries(accents)) {
      normalized = normalized.split(accented).join(base);
    }
    
    // Remove punctuation and special characters
    normalized = normalized.replace(/[^a-z0-9\s]/g, ' ');
    normalized = normalized.replace(/\s+/g, ' ').trim();
    
    return normalized;
  }
  
  function getLevenshteinDistance(a, b) {
    const aLen = a.length;
    const bLen = b.length;
    
    if (aLen === 0) return bLen;
    if (bLen === 0) return aLen;
    
    const matrix = Array(bLen + 1).fill(null).map(() => Array(aLen + 1).fill(0));
    
    for (let i = 0; i <= aLen; i++) matrix[0][i] = i;
    for (let j = 0; j <= bLen; j++) matrix[j][0] = j;
    
    for (let j = 1; j <= bLen; j++) {
      for (let i = 1; i <= aLen; i++) {
        const cost = a[i - 1] === b[j - 1] ? 0 : 1;
        matrix[j][i] = Math.min(
          matrix[j][i - 1] + 1,
          matrix[j - 1][i] + 1,
          matrix[j - 1][i - 1] + cost
        );
      }
    }
    
    return matrix[bLen][aLen];
  }
  
  function getFuzzyScore(query, text) {
    const queryNorm = normalizeText(query);
    const textNorm = normalizeText(text);
    
    if (!queryNorm || !textNorm) return 0;
    
    // Exact match
    if (textNorm === queryNorm) return 100;
    
    // Contains match (with flexible spacing)
    if (textNorm.includes(queryNorm)) return 95;
    
    // Contains with spaces removed (for "no space" typing)
    const textNoSpace = textNorm.replace(/\s/g, '');
    const queryNoSpace = queryNorm.replace(/\s/g, '');
    if (textNoSpace.includes(queryNoSpace)) return 92;
    
    // Contains with commas removed (for comma typing)
    const textNoComma = textNorm.replace(/,/g, '');
    const queryNoComma = queryNorm.replace(/,/g, '');
    if (textNoComma.includes(queryNoComma)) return 90;
    
    // Levenshtein distance for typos
    const distance = getLevenshteinDistance(queryNorm, textNorm);
    const maxLen = Math.max(queryNorm.length, textNorm.length);
    
    if (distance <= 2) {
      return Math.max(0, 85 - (distance * 10));
    }
    
    // Word-by-word matching with flexible spacing
    const queryWords = queryNorm.split(' ');
    const textWords = textNorm.split(' ');
    
    let matchedCount = 0;
    for (const qWord of queryWords) {
      if (qWord.length < 2) continue;
      for (const tWord of textWords) {
        // Direct match
        if (tWord === qWord) {
          matchedCount += 1;
          break;
        }
        // Contains match
        if (tWord.includes(qWord) || qWord.includes(tWord)) {
          matchedCount += 0.8;
          break;
        }
        // No space match
        if (tWord.replace(/\s/g, '').includes(qWord.replace(/\s/g, ''))) {
          matchedCount += 0.7;
          break;
        }
        // Fuzzy match for typos
        const wordDistance = getLevenshteinDistance(qWord, tWord);
        if (wordDistance <= 2 && Math.max(qWord.length, tWord.length) >= 3) {
          matchedCount += 0.6;
          break;
        }
      }
    }
    
    if (matchedCount > 0) {
      return Math.min(80, (matchedCount / queryWords.length) * 80);
    }
    
    return 0;
  }
  
  // ===== SEARCH CATALOG =====
  function searchCatalog(query) {
    if (!query || query.length < 1) return [];
    
    const results = [];
    const addedIds = new Set();
    
    allPerfumes.forEach(perfume => {
      let bestScore = 0;
      
      const brandScore = getFuzzyScore(query, perfume.brand);
      bestScore = Math.max(bestScore, brandScore);
      
      const nameScore = getFuzzyScore(query, perfume.name);
      bestScore = Math.max(bestScore, nameScore);
      
      if (perfume.productNumbers && perfume.productNumbers.length) {
        for (const num of perfume.productNumbers) {
          const numScore = getFuzzyScore(query, num);
          bestScore = Math.max(bestScore, numScore);
        }
      }
      
      if (bestScore < 70) {
        const allNotes = [
          ...(perfume.top_notes || []),
          ...(perfume.heart_notes || []),
          ...(perfume.base_notes || [])
        ];
        for (const note of allNotes) {
          const noteScore = getFuzzyScore(query, note);
          if (noteScore > bestScore) bestScore = noteScore;
        }
      }
      
      if (bestScore > 30 && !addedIds.has(perfume.id)) {
        results.push({ perfume, score: bestScore });
        addedIds.add(perfume.id);
      }
    });
    
    return results.sort((a, b) => b.score - a.score);
  }
  
  // ===== GET RECOMMENDATIONS =====
  function getRecommendations(perfume, currentProduct, limit = 2) {
    if (!perfume) return [];
    
    const recommendations = [];
    const addedIds = new Set();
    const perfumeGender = perfume.gender?.toLowerCase() || '';
    const perfumeBrand = perfume.brand?.toLowerCase() || '';
    const perfumeName = perfume.name;
    
    // STEP 1: Hardcoded recommendations
    const brandKey = Object.keys(HARDCODED_RECOMMENDATIONS).find(key => 
      perfumeBrand.includes(key) || key.includes(perfumeBrand)
    );
    
    if (brandKey && HARDCODED_RECOMMENDATIONS[brandKey][perfumeName]) {
      const hardcodedNames = HARDCODED_RECOMMENDATIONS[brandKey][perfumeName];
      
      for (const recName of hardcodedNames) {
        const product = allPerfumes.find(p => {
          const nameMatch = p.name === recName;
          const genderMatch = perfumeGender === '' || p.gender?.toLowerCase() === perfumeGender;
          const isNotCurrent = p.id !== currentProduct?.id;
          return nameMatch && genderMatch && isNotCurrent;
        });
        
        if (product && !addedIds.has(product.id)) {
          recommendations.push(product);
          addedIds.add(product.id);
          if (recommendations.length >= limit) break;
        }
      }
    }
    
    // STEP 2: Same brand recommendations
    if (recommendations.length < limit) {
      const sameBrandProducts = allPerfumes.filter(p => {
        const isSameBrand = p.brand?.toLowerCase() === perfumeBrand;
        const genderMatch = perfumeGender === '' || p.gender?.toLowerCase() === perfumeGender;
        const isNotCurrent = p.id !== currentProduct?.id;
        return isSameBrand && genderMatch && isNotCurrent;
      });
      
      for (const product of sameBrandProducts) {
        if (!addedIds.has(product.id)) {
          recommendations.push(product);
          addedIds.add(product.id);
          if (recommendations.length >= limit) break;
        }
      }
    }
    
    // STEP 3: Same gender recommendations
    if (recommendations.length < limit) {
      const sameGenderProducts = allPerfumes.filter(p => {
        const genderMatch = perfumeGender === '' || p.gender?.toLowerCase() === perfumeGender;
        const isNotCurrent = p.id !== currentProduct?.id;
        return genderMatch && isNotCurrent;
      }).slice(0, limit * 2);
      
      for (const product of sameGenderProducts) {
        if (!addedIds.has(product.id)) {
          recommendations.push(product);
          addedIds.add(product.id);
          if (recommendations.length >= limit) break;
        }
      }
    }
    
    return recommendations.slice(0, limit);
  }
  
  // ===== GET SAME BRAND PRODUCTS =====
  function getSameBrandProducts(perfume, currentProduct, limit = 2) {
    if (!perfume) return [];
    
    const perfumeBrand = perfume.brand?.toLowerCase() || '';
    const perfumeGender = perfume.gender?.toLowerCase() || '';
    
    const sameBrand = allPerfumes.filter(p => {
      const isSameBrand = p.brand?.toLowerCase() === perfumeBrand;
      const genderMatch = perfumeGender === '' || p.gender?.toLowerCase() === perfumeGender;
      const isNotCurrent = p.id !== currentProduct?.id;
      return isSameBrand && genderMatch && isNotCurrent;
    });
    
    return sameBrand.slice(0, limit);
  }
  
  // ===== RENDER FUNCTIONS =====
  function formatPrice(priceInCents) {
    return '€' + (priceInCents / 100).toFixed(2);
  }
  
  function renderCatalogItem(perfume) {
