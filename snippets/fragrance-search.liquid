  // ===== CONFIGURATION =====
  const STORE_URL = 'https://{{ shop.domain }}';
  let allPerfumes = [];
  let catalogReady = false;
  let currentCartCount = 0;

  // ===== HARDCODED RECOMMENDATIONS =====
  const HARDCODED_RECOMMENDATIONS = {
