  // ===== PRODUCT VARIABLES =====
  let currentView = 'search';
  let currentSearchQuery = '';
  let searchTimer = null;

  // DOM Elements
  const stickyButton = document.getElementById('fcStickyButton');
  const searchPopup = document.getElementById('fcSearchPopup');
  const searchInput = document.getElementById('fcSearchInput');
  const clearSearch = document.getElementById('fcClearSearch');
  const steps = document.getElementById('fcSteps');
  const content = document.getElementById('fcContent');
  
  // Offer elements
  const offerBanner = document.getElementById('fcOfferBanner');
  const offerStatus = document.getElementById('fcOfferStatus');
  const offerProgress = document.getElementById('fcOfferProgress');
  const offerMessage = document.getElementById('fcOfferMessage');
  const offerSubtext = document.getElementById('fcOfferSubtext');

  // ===== HELPER FUNCTIONS =====
  function normalizeText(text) {
    if (!text) return '';
    return text.toLowerCase()
      .normalize('NFD')
      .replace(/[\u0300-\u036f]/g, '')
      .replace(/[^a-z0-9\s]/g, ' ')
      .replace(/\s+/g, ' ')
      .trim();
  }

  function getSearchVariants(query) {
    const variants = new Set();
    const normalized = normalizeText(query);
    variants.add(normalized);
    
    const words = normalized.split(' ').filter(w => w.length > 0);
    words.forEach(word => variants.add(word));
    
    if (words.length > 1) {
      variants.add(words.join(''));
      variants.add([...words].reverse().join(''));
    }
    
    if (/\d+/.test(query)) {
      const numbers = query.match(/\d+/g);
      numbers.forEach(num => variants.add(num));
    }
    
    return Array.from(variants).filter(v => v.length >= 1).slice(0, 20);
  }

  function searchProducts(query) {
    if (!query || query.length < 1) return [];
    
    const searchVariants = getSearchVariants(query);
    const results = [];
    const addedIds = new Set();
    
    hardcodedProducts.forEach(product => {
      let bestScore = 0;
      
      // Check number match (highest priority)
      if (product.number && searchVariants.includes(product.number)) {
        bestScore = 100;
      }
      
      // Check search terms
      if (bestScore < 95 && product.searchTerms) {
        for (const term of product.searchTerms) {
          const termNorm = normalizeText(term);
          for (const variant of searchVariants) {
            if (termNorm.includes(variant) || variant.includes(termNorm)) {
              bestScore = Math.max(bestScore, 90);
            }
          }
        }
      }
      
      // Check title
      if (bestScore < 90) {
        const titleNorm = normalizeText(product.title);
        for (const variant of searchVariants) {
          if (titleNorm.includes(variant)) {
            bestScore = Math.max(bestScore, 85);
          }
        }
      }
      
      // Check brand
      if (bestScore < 85) {
        const brandNorm = normalizeText(product.brand);
        for (const variant of searchVariants) {
          if (brandNorm.includes(variant)) {
            bestScore = Math.max(bestScore, 80);
          }
        }
      }
      
      if (bestScore > 30 && !addedIds.has(product.id)) {
        results.push({ product, score: bestScore });
        addedIds.add(product.id);
      }
    });
    
    return results.sort((a, b) => b.score - a.score);
  }

  function getRecommendationsForProduct(product) {
    if (!product) return [];
    
    // Find other products from the same brand
    return hardcodedProducts.filter(p => 
      p.brandKey === product.brandKey && 
      p.id !== product.id &&
      p.gender === product.gender
    ).slice(0, 2);
  }

  function getPopularSuggestions() {
    return hardcodedProducts.slice(0, 6);
  }

  // ===== RENDER FUNCTIONS =====
  function renderProductCard(product, badge) {
    const priceFormatted = '€' + (product.price / 100).toFixed(2);
    
    return `
      <div class="fc-product-card">
        <div class="fc-badge">${badge}</div>
        <div class="fc-product-inner">
          <img class="fc-product-image" src="${product.image}" alt="${product.title}" loading="lazy" onerror="this.src='https://via.placeholder.com/150x150?text=Perfume'">
          <div class="fc-product-title">${product.title}</div>
          <div class="fc-product-price">${priceFormatted}</div>
          <button class="fc-add-to-cart" onclick="event.stopPropagation(); window.fcAddToCart('${product.url}', event)">Add to Cart</button>
          <div>
            <span class="fc-view-link" onclick="event.stopPropagation(); window.fcViewDetails('${product.url}')">View Details</span>
          </div>
        </div>
      </div>
    `;
  }

  function renderProductListItem(product) {
    const priceFormatted = '€' + (product.price / 100).toFixed(2);
    
    return `
      <div class="fc-product-item" onclick="window.fcViewDetails('${product.url}')">
        <img class="fc-product-image-small" src="${product.image}" alt="${product.title}" loading="lazy" onerror="this.src='https://via.placeholder.com/60x60?text=Perfume'">
        <div class="fc-product-info">
          <div class="fc-product-name">${product.title}</div>
          <div class="fc-product-brand">${product.brand}</div>
          <div class="fc-product-price-small">${priceFormatted}</div>
        </div>
      </div>
    `;
  }

  function renderSuggestions() {
    const suggestions = getPopularSuggestions();
    if (suggestions.length === 0) return '';
    
    let html = `<div class="fc-suggestions-title">✨ Popular Fragrances</div>`;
    suggestions.forEach(product => {
      const priceFormatted = '€' + (product.price / 100).toFixed(2);
      
      html += `
        <div class="fc-suggestion-item" onclick="window.fcViewDetails('${product.url}')">
          <img class="fc-suggestion-image" src="${product.image}" alt="${product.title}" loading="lazy">
          <div class="fc-suggestion-info">
            <div class="fc-suggestion-name">${product.title}</div>
            <div class="fc-suggestion-price">${priceFormatted}</div>
          </div>
        </div>
      `;
    });
    
    return html;
  }

  function performSearch(query) {
    currentSearchQuery = query;
    content.innerHTML = '<div class="fc-loading">Searching...</div>';
    
    setTimeout(() => {
      const results = searchProducts(query);
      
      let html = '';
      
      if (results.length > 0) {
        html += `<div class="fc-section-title">Search Results (${results.length})</div>`;
        
        results.slice(0, 12).forEach(match => {
          html += renderProductListItem(match.product);
        });
      } else {
        html = '<div class="fc-no-results">No products found for "' + query + '"</div>';
        html += renderSuggestions();
      }
      
      content.innerHTML = html;
    }, 300);
  }

  function showProductDetail(product) {
    currentView = 'detail';
    steps.style.display = 'none';
    
    const recommendations = getRecommendationsForProduct(product);
    const priceFormatted = '€' + (product.price / 100).toFixed(2);
    
    let html = `
      <button class="fc-back-btn" onclick="window.fcGoBack()">Back</button>
      <div class="fc-subsection-title" style="margin: 0 20px 15px 20px;">${product.title}</div>
    `;
    
    // Show the main product
    html += '<div class="fc-grid-2col">';
    html += renderProductCard(product, 'Selected');
    
    // Show recommendations
    if (recommendations.length > 0) {
      html += renderProductCard(recommendations[0], 'You might like');
    } else {
      html += `<div class="fc-product-card" style="visibility: hidden;"></div>`;
    }
    
    html += '</div>';
    
    // Add product details
    html += `
      <div class="fc-detailed-view" style="margin: 0 20px 20px 20px; padding: 20px; background: #FEFCF9; border-radius: 24px;">
        <div style="display: flex; gap: 20px; margin-bottom: 20px;">
          <img src="${product.image}" style="width: 100px; height: 100px; object-fit: contain; border-radius: 12px;" alt="${product.title}">
          <div>
            <div style="font-size: 14px; color: #C41E3A; font-weight: 600; margin-bottom: 5px;">${product.brand}</div>
            <div style="font-size: 24px; font-weight: 800; color: #2C2420; margin-bottom: 8px;">No. ${product.number}</div>
            <div style="font-size: 18px; font-weight: 700; color: #C41E3A;">${priceFormatted}</div>
          </div>
        </div>
        <div style="border-top: 1px solid #EDE5DC; padding-top: 15px;">
          <div style="font-size: 13px; color: #4A3F39; line-height: 1.6;">
            Inspired by ${product.searchTerms[0] || product.title.replace('No. ' + product.number + '— Senteur Inspirée ', '')}
          </div>
        </div>
      </div>
    `;
    
    content.innerHTML = html;
  }

  // ===== GLOBAL FUNCTIONS =====
  window.fcToggleSearch = function() {
    if (searchPopup.classList.contains('active')) {
      searchPopup.classList.remove('active');
    } else {
      searchPopup.classList.add('active');
      if (searchInput) searchInput.focus();
      fetchCartAndUpdate();
    }
  };

  window.fcAddToCart = function(productUrl, event) {
    if (event) event.stopPropagation();
    
    const btn = event?.target || document.activeElement;
    const originalText = btn.innerText;
    const originalBackground = btn.style.background;
    
    btn.innerText = 'Adding...';
    btn.disabled = true;
    
    // Extract handle from URL
    let handle = '';
    if (typeof productUrl === 'string' && productUrl.includes('/products/')) {
      handle = productUrl.split('/products/')[1].split('?')[0].split('#')[0];
    }
    
    if (!handle) {
      btn.innerText = 'Error';
      setTimeout(() => {
        btn.innerText = originalText;
        btn.disabled = false;
      }, 2000);
      return;
    }
    
    // Fetch product to get variant ID
    fetch(`/products/${handle}.js`)
      .then(response => response.json())
      .then(product => {
        let variantId = null;
        if (product.variants && product.variants.length > 0) {
          variantId = product.variants[0].id;
        }
        
        if (!variantId) throw new Error('No variant available');
        
        return fetch('/cart/add.js', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ id: variantId, quantity: 1 })
        });
      })
      .then(response => response.json())
      .then(() => {
        btn.innerText = '✓ Added!';
        btn.style.background = '#2E7D32';
        fetchCartAndUpdate();
        
        setTimeout(() => {
          btn.innerText = originalText;
          btn.style.background = originalBackground || '#C41E3A';
          btn.disabled = false;
        }, 2000);
      })
      .catch(error => {
        console.error('Add to cart error:', error);
        btn.innerText = 'Error';
        btn.style.background = '#c62828';
        
        setTimeout(() => {
          btn.innerText = originalText;
          btn.style.background = originalBackground || '#C41E3A';
          btn.disabled = false;
        }, 2000);
      });
  };

  window.fcViewDetails = function(url) {
    // Find product by URL and show detailed view
    const product = hardcodedProducts.find(p => p.url === url);
    if (product) {
      showProductDetail(product);
    } else {
      window.location.href = url;
    }
  };

  window.fcGoBack = function() {
    currentView = 'search';
    if (currentSearchQuery.length >= 1) {
      performSearch(currentSearchQuery);
    } else {
      steps.style.display = 'block';
      content.innerHTML = '';
    }
  };

  // ===== CART FUNCTIONS =====
  function updateOfferDisplay(itemCount) {
    if (!offerStatus || !offerProgress || !offerMessage || !offerSubtext) return;
    
    const percentage = Math.min((itemCount / 3) * 100, 100);
    offerProgress.style.width = percentage + '%';
    
    if (itemCount >= 3) {
      offerStatus.textContent = '🎉 FREE!';
      offerSubtext.textContent = 'You qualify for a free gift!';
      offerMessage.textContent = '🎉 You qualify for a FREE gift!';
      offerBanner.classList.add('qualified');
    } else {
      const needed = 3 - itemCount;
      offerStatus.textContent = `${itemCount}/3`;
      offerSubtext.textContent = `Add ${needed} more for a free gift`;
      offerMessage.textContent = `Add ${needed} more item${needed > 1 ? 's' : ''} to get a free gift`;
      offerBanner.classList.remove('qualified');
    }
  }

  function fetchCartAndUpdate() {
    return fetch('/cart.js')
      .then(response => response.json())
      .then(cart => {
        updateOfferDisplay(cart.item_count);
        return cart;
      })
      .catch(error => {
        console.error('Error fetching cart:', error);
        return { item_count: 0 };
      });
  }

  // ===== SEARCH HANDLER =====
  function handleSearch() {
    const query = searchInput.value.trim();
    
    if (query.length < 1) {
      if (currentView !== 'detail') {
        steps.style.display = 'block';
        content.innerHTML = '';
      }
      return;
    }
    
    steps.style.display = 'none';
    currentView = 'search';
    
    clearTimeout(searchTimer);
    searchTimer = setTimeout(() => performSearch(query), 300);
  }

  // ===== INITIALIZATION =====
  document.addEventListener('DOMContentLoaded', function() {
    searchInput.addEventListener('keyup', handleSearch);
    
    clearSearch.addEventListener('click', function() {
      searchInput.value = '';
      searchInput.focus();
      steps.style.display = 'block';
      content.innerHTML = '';
      currentView = 'search';
    });
    
    setTimeout(fetchCartAndUpdate, 500);
    
    // Close popup when clicking outside
    document.addEventListener('click', function(event) {
      if (!searchPopup.contains(event.target) && !stickyButton.contains(event.target) && searchPopup.classList.contains('active')) {
        searchPopup.classList.remove('active');
      }
    });
    
    // Close on ESC
    document.addEventListener('keydown', function(e) {
      if (e.key === 'Escape' && searchPopup.classList.contains('active')) {
        searchPopup.classList.remove('active');
      }
    });
    
    searchPopup.addEventListener('click', function(e) {
      e.stopPropagation();
    });
    
    console.log('✓ Search system initialized with', hardcodedProducts.length, 'products');
  });
})();
</script>