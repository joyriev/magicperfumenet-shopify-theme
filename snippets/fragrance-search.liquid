      'Bleu de Chanel': ['Allure Homme Sport', 'Coco Mademoiselle', 'Mademoiselle'],
      'Allure Homme Sport': ['Bleu de Chanel', 'Coco Mademoiselle', 'Mademoiselle']
    },
