      "blocks": {
        "review_Ya7zk4": {
          "type": "review",
          "settings": {
            "content": "<p>\"This is my first purchase and I'm delighted. I'll never buy my perfume anywhere else again. I had never found a perfume alternative that smells truly authentic and consistent.\"</p>",
